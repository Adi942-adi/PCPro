PORT=5000
NODE_ENV=development
LOG_LEVEL=debug
MONGO_URI=mongodb://127.0.0.1:27017/pcpro
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=replace-with-a-random-64-char-secret
JWT_EXPIRES_IN=15m
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_DAYS=21
PASSWORD_RESET_TOKEN_MINUTES=30
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=false
AUTH_ACCESS_COOKIE_MAX_AGE_MS=900000
SUPER_ADMIN_EMAILS=admin@pcpro.local
STRIPE_SECRET_KEY=
ALLOW_MOCK_PAYMENTS=true
CURRENCY=usd
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=PCPro <your-email@gmail.com>
SMTP_TEST_TO=your-email@gmail.com
VAPID_SUBJECT=mailto:admin@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
QUERY_CACHE_ENABLED=true
QUERY_CACHE_TTL_MS=20000
QUERY_CACHE_MAX_ENTRIES=1500
RATE_LIMIT_GENERAL_MAX=240
RATE_LIMIT_AUTH_MAX=30
RATE_LIMIT_ADMIN_MAX=120
JSON_BODY_LIMIT=250kb
SERVER_ORIGIN=http://localhost:5000

# OAuth Configuration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
